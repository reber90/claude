# Supabase: copy these from your Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Admin password for the dashboard at /admin
# Defaults to admin123 if not set. Change this to something strong before going live.
ADMIN_PASSWORD=admin123
